{
  "compilerOptions": {
    "target": "ES6",
    "module": "ES2015",
    "moduleResolution": "node",
    "outDir": "app/static/app/js/compiled",
    "rootDir": "app/static/app/ts",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true
  },
  "include": [
    "app/static/app/ts/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
