# Frontend .env Example — Safe to commit!
# .env banao is template se, real values dalo, .env ko KABHI commit mat karo

# Backend API URL (leave empty to use Vite proxy — recommended for development)
# VITE_API_URL=

# Agar aap production pe deploy karein toh:
# VITE_API_URL=https://your-backend-domain.com/api
